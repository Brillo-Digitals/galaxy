

<MenuWidget>:
    canvas:
        Color:
            rgba : 0, 0, 0, 0.8
        Rectangle:
            size: self.size
    Label:
        font_size: dp(60)
        font_name:'fonts/Sackers-Gothic-Std-Light.ttf'
        text: root.parent.menu_title
        pos_hint: {"center_x": .5, "center_y": .6}
    Label:
		text: root.parent.score_txt_game_over
		font_size: dp(21)
        font_name:'fonts/Eurostile.ttf'
		size_hint: .18, .18
		pos_hint: {"center_x": .5, "center_y": .45}
    Button:
        font_size: dp(30)
        font_name:'fonts/Eurostile.ttf'
        text: root.parent.menu_button_title
        pos_hint: {"center_x": .5, "center_y": .3}
        size_hint: .2, .15
        on_press: root.parent.on_menu_button_press()
        background_normal: ''
        background_color: 1,.3, .4, .85